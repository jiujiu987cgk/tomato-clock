                        </radialGradient>
                    </defs>
                    <circle cx="160" cy="160" r="145" fill="none" stroke="#FFE4E6" stroke-width="3" opacity="0.5"/>
                    <circle cx="160" cy="160" r="135" fill="none" stroke="#FFCCCF" stroke-width="4" opacity="0.4"/>
                    <circle class="timer-bg-circle" cx="160" cy="160" r="125" stroke="url(#wheelGradient)" stroke-width="24" fill="none"/>
                    <g id="wheel-spokes" class="wheel-spokes">
                    <line x1="160" y1="38" x2="160" y2="282" stroke="#FFD0D6" stroke-width="0.8" stroke-linecap="round" opacity="0.15"/>
