    <script src="assets/js/common.js"></script>
    <script>
        // ---- 数据读取辅助 ----
        function getCompletions() {
            return JSON.parse(localStorage.getItem('pomodoro_completions') || '{}');
        }
        function getStreak() {
            return JSON.parse(localStorage.getItem('pomodoro_streak') || '{"count":0,"lastDate":""}');
        }
        function getTasks() {
            return JSON.parse(localStorage.getItem('pomodoro_tasks') || '[]');
        }
        function getInterruptions() {
            return JSON.parse(localStorage.getItem('pomodoro_interruptions') || '[]');
        }
        function getEnergyData() {
            return JSON.parse(localStorage.getItem('pomodoro_energy') || 'null');
        }
        function getFocusRecords() {
            return JSON.parse(localStorage.getItem('pomodoro_focus_records') || '[]');
        }
        function getTodayKey() {
            return new Date().toISOString().split('T')[0];
        }
        function getDateKey(date) {
            return date.toISOString().split('T')[0];
        }
        function getDayOfWeek(date) {
            // 返回 0=周日 1=周一 ... 6=周六
            return date.getDay();
        }

        // ---- 1. 统计卡片 ----
        function updateStatCards() {
            const completions = getCompletions();
            const todayKey = getTodayKey();
            // 今日番茄数
            const todayCount = completions[todayKey] || 0;
            document.querySelector('.stat-card:nth-child(1) .stat-value').textContent = todayCount;

            // 连续天数
            const streak = getStreak();
            document.querySelector('.stat-card:nth-child(2) .stat-value').textContent = streak.count || 0;

            // 完成率
            const tasks = getTasks();
            const completed = tasks.filter(t => t.completed).length;
            const totalTasks = tasks.length || 1;
            const rate = Math.round((completed / totalTasks) * 100);
            document.querySelector('.stat-card:nth-child(3) .stat-value').textContent = rate + '%';

            // 专注时长 (今日完成的番茄数 × 25分钟)
            const focusMinutes = todayCount * 25;
            const hours = Math.floor(focusMinutes / 60);
            const mins = focusMinutes % 60;
            let durationText = '';
            if (hours > 0) {
                durationText = hours + 'h' + (mins > 0 ? mins + 'm' : '');
            } else {
                durationText = mins + 'm';
            }
            document.querySelector('.stat-card:nth-child(4) .stat-value').textContent = durationText || '0m';
        }

        // ---- 2. 番茄链热力图 (7天) ----
        function updateHeatmap() {
            const completions = getCompletions();
            const grid = document.getElementById('heatmap-grid');
            grid.innerHTML = '';
            const today = new Date();
            const dayLabels = ['日', '一', '二', '三', '四', '五', '六'];
            
            // 生成最近7天，从6天前到今天
            for (let i = 6; i >= 0; i--) {
                const d = new Date(today);
                d.setDate(d.getDate() - i);
                const key = getDateKey(d);
                const count = completions[key] || 0;
                const dow = getDayOfWeek(d);

                let level = 0;
                if (count >= 1) level = 1;
                if (count >= 3) level = 2;
                if (count >= 5) level = 3;
                if (count >= 8) level = 4;

                const cell = document.createElement('div');
                cell.className = 'heatmap-cell level-' + level;
                cell.title = key + ' 完成 ' + count + ' 个番茄';

                // 小番茄 SVG
                const tomatoSvg = count > 0 ? `
                    <svg viewBox="0 0 24 24" fill="none">
                        <ellipse cx="12" cy="14" rx="7" ry="6.5" fill="white" opacity="0.9"/>
                        <ellipse cx="10" cy="12" rx="2.5" ry="2" fill="white" opacity="0.6" transform="rotate(-20 10 12)"/>
                        <path d="M12 8 Q10 6 8 6.5" stroke="#B5EAD7" stroke-width="1.2" fill="none" stroke-linecap="round"/>
                        <ellipse cx="8.5" cy="6.5" rx="1.8" ry="2.5" fill="#B5EAD7" opacity="0.9" transform="rotate(-25 8.5 6.5)"/>
                        ${level >= 4 ? '<g transform="translate(15,10) scale(0.5)"><polygon points="0,-4 1.2,-1 4,-1 2,1 2.5,4 0,2 -2.5,4 -2,1 -4,-1 -1.2,-1" fill="#FFD700" opacity="0.9"/></g>' : ''}
                    </svg>
                ` : '';
                cell.innerHTML = tomatoSvg;
                grid.appendChild(cell);
            }

            // 更新 streak badge
            const streak = getStreak();
            const badge = document.querySelector('.streak-badge span');
            if (badge) {
                badge.textContent = '连续' + (streak.count || 0) + '天啦';
            }
        }

        // ---- 3. 精力周期图谱 (折线图) ----
        function updateEnergyChart() {
            // 默认时间段数据：早上、上午、中午、下午、傍晚、晚上
            const periods = ['6-8', '8-10', '10-12', '12-14', '14-16', '16-18', '18-20', '20-22'];
            const periodLabels = ['6时', '8时', '10时', '12时', '14时', '16时', '18时', '20时'];
            
            // 尝试从 localStorage 读取精力数据，若无则使用默认值
            let energyValues = getEnergyData();
            if (!energyValues || !Array.isArray(energyValues) || energyValues.length !== periods.length) {
                // 使用默认精力曲线：早高晚低
                energyValues = [70, 85, 90, 60, 75, 80, 65, 50];
            }

            const svg = document.querySelector('.chart-section svg');
            const width = 350, height = 120;
            const padding = 15;
            const chartW = width - padding * 2;
            const chartH = height - padding * 2;
            const maxVal = 100;
            const stepX = chartW / (periods.length - 1);

            // 生成路径
            let pathD = '';
            let areaD = '';
            const points = [];
            energyValues.forEach((val, i) => {
                const x = padding + i * stepX;
                const y = padding + chartH - (val / maxVal) * chartH;
                points.push({ x, y, val });
                if (i === 0) {
                    pathD += `M${x},${y}`;
                    areaD += `M${x},${y}`;
                } else {
                    // 使用平滑曲线
                    const prev = points[i - 1];
                    const cpx = (prev.x + x) / 2;
                    pathD += ` Q${cpx},${prev.y} ${x},${y}`;
                    areaD += ` Q${cpx},${prev.y} ${x},${y}`;
                }
            });
            areaD += ` L${points[points.length - 1].x},${height - padding} L${padding},${height - padding} Z`;

            // 更新 SVG 内容
            svg.innerHTML = `
                <defs>
                    <linearGradient id="energyGradient" x1="0%" y1="0%" x2="0%" y2="100%">
                        <stop offset="0%" style="stop-color:var(--color-wisteria);stop-opacity:0.5" />
                        <stop offset="100%" style="stop-color:var(--color-wisteria);stop-opacity:0.1" />
                    </linearGradient>
                </defs>
                <path class="chart-area" d="${areaD}"/>
                <path class="chart-path" d="${pathD}"/>
                ${points.map(p => `<circle class="chart-node" cx="${p.x}" cy="${p.y}" r="5"/>`).join('')}
                ${points.map(p => `<circle cx="${p.x}" cy="${p.y - 2}" r="1.8" fill="#FF6B6B"/>`).join('')}
                ${points.map((p, i) => `<text x="${p.x}" y="${height - 3}" text-anchor="middle" font-size="8" fill="var(--color-warm-gray)" font-family="var(--font-family-display)">${periodLabels[i]}</text>`).join('')}
                ${points.map(p => `<text x="${p.x}" y="${p.y - 10}" text-anchor="middle" font-size="9" fill="var(--color-deep-purple-gray)" font-weight="bold" font-family="var(--font-family-display)">${p.val}%</text>`).join('')}
            `;
        }

        // ---- 4. 中断归因饼图 ----
        function updatePieChart() {
            const interruptions = getInterruptions();
            const totalInterruptions = interruptions.length;
            const internalCount = interruptions.filter(i => i.type === 'internal').length;
            const externalCount = interruptions.filter(i => i.type === 'external').length;
            const totalInterrupt = internalCount + externalCount || 1;
            const internalPct = Math.round((internalCount / totalInterrupt) * 100);
            const externalPct = 100 - internalPct;

            const pieChart = document.querySelector('.pie-chart');
            if (pieChart) {
                const warmPink = getComputedStyle(document.documentElement).getPropertyValue('--color-warm-pink').trim() || '#FFB3BA';
                const wisteria = getComputedStyle(document.documentElement).getPropertyValue('--color-wisteria').trim() || '#C9A7EB';
                pieChart.style.background = `conic-gradient(${warmPink} 0% ${internalPct}%, ${wisteria} ${internalPct}% 100%)`;
            }
            document.querySelector('.pie-center').textContent = totalInterruptions + '次';
            const legendItems = document.querySelectorAll('.legend-item');
            if (legendItems.length >= 2) {
                legendItems[0].querySelector('.legend-value').textContent = internalPct + '%';
                legendItems[1].querySelector('.legend-value').textContent = externalPct + '%';
            }
        }

        // ---- 5. 散点图 (承诺-挑战散点图) ----
        function updateScatterPlot() {
            const tasks = getTasks();
            const container = document.querySelector('.scatter-plot');
            // 保留坐标轴和标签
            const axes = container.querySelectorAll('.scatter-axis, .axis-label-x, .axis-label-y');
            container.innerHTML = '';
            axes.forEach(el => container.appendChild(el));

            if (tasks.length === 0) {
                // 显示空状态
                const emptyMsg = document.createElement('div');
                emptyMsg.style.cssText = 'position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:12px;color:var(--color-warm-gray);text-align:center;';
                emptyMsg.textContent = '暂无任务数据';
                container.appendChild(emptyMsg);
                return;
            }

            // 用任务数据生成散点：X轴=承诺度(commitment) Y轴=挑战度(实际番茄/预估番茄)
            const maxCommitment = Math.max(...tasks.map(t => t.commitment || 1), 5);
            const maxChallenge = Math.max(...tasks.map(t => (t.completed ? (t.tomatoes || 1) : 1)), 5);

            tasks.forEach((task, index) => {
                const commitment = task.commitment || 1;
                const challenge = task.completed ? (task.tomatoes || 1) : 1;
                // 归一化到 10%~90% 范围
                const xPct = 10 + (commitment / maxCommitment) * 70;
                const yPct = 10 + (1 - challenge / maxChallenge) * 70;
                // 限制边界
                const x = Math.max(5, Math.min(90, xPct));
                const y = Math.max(5, Math.min(90, yPct));

                const point = document.createElement('div');
                point.className = 'scatter-point';
                point.style.left = x + '%';
                point.style.top = y + '%';
                point.title = task.title + ' (承诺度:' + commitment + ', 番茄数:' + (task.tomatoes || 1) + ')';

                // 随机选择动物颜色
                const colors = ['#E8D5F5', '#FFF3E0', '#C9A7EB', '#F5CC60', '#FFB3BA'];
                const strokes = ['#B08BD9', '#E8C880', '#8B6BB8', '#8B6010', '#E87080'];
                const cIdx = index % colors.length;

                point.innerHTML = `
                    <svg viewBox="0 0 36 36" fill="none">
                        <ellipse cx="12" cy="11" rx="4" ry="7" fill="${colors[cIdx]}" stroke="${strokes[cIdx]}" stroke-width="1"/>
                        <ellipse cx="24" cy="11" rx="4" ry="7" fill="${colors[cIdx]}" stroke="${strokes[cIdx]}" stroke-width="1"/>
                        <ellipse cx="12" cy="13" rx="2" ry="4.5" fill="${colors[cIdx === 0 ? 1 : 0]}"/>
                        <ellipse cx="24" cy="13" rx="2" ry="4.5" fill="${colors[cIdx === 0 ? 1 : 0]}"/>
                        <circle cx="18" cy="23" r="10" fill="${colors[cIdx]}" stroke="${strokes[cIdx]}" stroke-width="1.2"/>
                        <ellipse cx="18" cy="26" rx="6.5" ry="4.5" fill="#F5EEFF"/>
                        <ellipse cx="15" cy="21" rx="1.8" ry="2" fill="#2D1810"/>
                        <ellipse cx="21" cy="21" rx="1.8" ry="2" fill="#2D1810"/>
                        <circle cx="14.5" cy="20.2" r="0.6" fill="white"/>
                        <circle cx="20.5" cy="20.2" r="0.6" fill="white"/>
                        <path d="M13.5 19.8 L12.5 18.5" stroke="#2D1810" stroke-width="0.6" fill="none" stroke-linecap="round"/>
                        <path d="M22.5 19.8 L23.5 18.5" stroke="#2D1810" stroke-width="0.6" fill="none" stroke-linecap="round"/>
                        <ellipse cx="18" cy="25" rx="2" ry="1.5" fill="#FF6B6B"/>
                        <path d="M15 28 Q18 30 21 28" stroke="#3D2010" stroke-width="1" fill="none" stroke-linecap="round"/>
                        <ellipse cx="11" cy="24" rx="2.2" ry="1.5" fill="#FFB3BA" opacity="0.6"/>
                        <ellipse cx="25" cy="24" rx="2.2" ry="1.5" fill="#FFB3BA" opacity="0.6"/>
                        <g transform="translate(8,16) scale(0.28)"><polygon points="0,-4 1.2,-1 4,-1 2,1 2.5,4 0,2 -2.5,4 -2,1 -4,-1 -1.2,-1" fill="#FFD700" opacity="0.85"/></g>
                    </svg>
                `;
                container.appendChild(point);
            });
        }

        // ---- 6. 中断偏差列表 ----
        function updateInterruptionList() {
            const interruptions = getInterruptions();
            const container = document.querySelector('.deviation-list');
            const existingItems = container.querySelectorAll('.deviation-item');
            existingItems.forEach(item => item.remove());
            
            const h3 = container.querySelector('h3');
            
            if (interruptions.length === 0) {
                const emptyDiv = document.createElement('div');
                emptyDiv.style.cssText = 'text-align:center;padding:20px;color:var(--color-warm-gray);font-size:14px;';
                emptyDiv.textContent = '还没有中断记录哦~ 继续保持专注！';
                container.appendChild(emptyDiv);
                return;
            }

            // 显示最近的中断记录（最多10条），按时间倒序
            const recent = [...interruptions].reverse().slice(0, 10);
            recent.forEach(item => {
                const div = document.createElement('div');
                div.className = 'deviation-item';
                const time = new Date(item.time);
                const timeStr = time.toLocaleString('zh-CN', { month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' });
                const typeLabel = item.type === 'internal' ? '内部中断' : '外部中断';
                const reason = item.reason || '未记录原因';
                
                div.innerHTML = `
                    <div class="deer-referee">
                        <svg viewBox="0 0 32 32" fill="none">
                            <ellipse cx="11" cy="5" rx="2.2" ry="4" transform="rotate(-15 11 5)" fill="#B07810" stroke="#6B4808" stroke-width="0.7"/>
                            <ellipse cx="21" cy="5" rx="2.2" ry="4" transform="rotate(15 21 5)" fill="#B07810" stroke="#6B4808" stroke-width="0.7"/>
                            <circle cx="9.5" cy="2.5" r="0.8" fill="#D49818"/>
                            <circle cx="22.5" cy="2.5" r="0.8" fill="#D49818"/>
                            <ellipse cx="9" cy="9" rx="2.2" ry="3" fill="#F5CC60" stroke="#8B6010" stroke-width="0.7"/>
                            <ellipse cx="23" cy="9" rx="2.2" ry="3" fill="#F5CC60" stroke="#8B6010" stroke-width="0.7"/>
                            <circle cx="16" cy="18" r="9" fill="#F5CC60" stroke="#8B6010" stroke-width="1"/>
                            <ellipse cx="16" cy="20.5" rx="5.5" ry="4" fill="#FFE8B0"/>
                            <ellipse cx="13" cy="16" rx="1.8" ry="2" fill="#2D1810"/>
                            <ellipse cx="19" cy="16" rx="1.8" ry="2" fill="#2D1810"/>
                            <circle cx="12.5" cy="15.2" r="0.6" fill="white"/>
                            <circle cx="18.5" cy="15.2" r="0.6" fill="white"/>
                            <path d="M11.5 14.5 L10.5 13.2" stroke="#2D1810" stroke-width="0.6" fill="none" stroke-linecap="round"/>
                            <path d="M20.5 14.5 L21.5 13.2" stroke="#2D1810" stroke-width="0.6" fill="none" stroke-linecap="round"/>
                            <ellipse cx="16" cy="19.5" rx="2" ry="1.5" fill="#FF6B6B"/>
                            <path d="M13 22.5 Q16 25 19 22.5" stroke="#3D2010" stroke-width="0.9" fill="none" stroke-linecap="round"/>
                            <ellipse cx="9" cy="19" rx="2" ry="1.5" fill="#FFCCAA" opacity="0.7"/>
                            <ellipse cx="23" cy="19" rx="2" ry="1.5" fill="#FFCCAA" opacity="0.7"/>
                            <rect x="7" y="26" width="18" height="4.5" rx="2" fill="#C9A7EB" stroke="#8B6BB8" stroke-width="0.8"/>
                            <rect x="9" y="27.5" width="14" height="1.5" rx="0.7" fill="#FFF9F6"/>
                            <g transform="translate(6.5,12) scale(0.25)"><polygon points="0,-4 1.2,-1 4,-1 2,1 2.5,4 0,2 -2.5,4 -2,1 -4,-1 -1.2,-1" fill="#FFD700" opacity="0.85"/></g>
                        </svg>
                    </div>
                    <div class="deviation-info">
                        <div class="deviation-task">${reason}</div>
                        <div class="deviation-time">${timeStr} · ${typeLabel}</div>
                    </div>
                    <div class="deviation-score ${item.type === 'internal' ? 'score-normal' : 'score-bad'}">${item.type === 'internal' ? '内' : '外'}</div>
                `;
                container.insertBefore(div, h3.nextSibling);
            });
        }

        // ---- 主入口 ----
        function loadDashboardData() {
            updateStatCards();
            updateHeatmap();
            updateEnergyChart();
            updatePieChart();
            updateScatterPlot();
            updateInterruptionList();
        }

        function openPage(page) {
            window.location.href = page;
        }

        loadDashboardData();
    </script>
</body>
