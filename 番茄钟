            box-shadow: 0 4px 16px rgba(0,0,0,0.1);
            position: relative;
            z-index: 1;
        }
        
        .onboarding-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        }
        
        .onboarding-btn:active {
            transform: translateY(0);
