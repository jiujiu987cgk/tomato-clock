    <script src="assets/js/common.js"></script>
    <script>
        let timer = null;
        let isRunning = false;
        let totalFocusSeconds = 25 * 60;
        let timeLeft = 25 * 60;
        
        function loadSettings() {
            const saved = localStorage.getItem('pomodoro_settings');
            if (saved) {
                const s = JSON.parse(saved);
                totalFocusSeconds = (s.focusDuration || 25) * 60;
                timeLeft = totalFocusSeconds;
            }
        }
        
        function initHomeTimer() {
            loadSettings();
            const circle = document.getElementById('progress-circle');
            const radius = 125;
            const circumference = radius * 2 * Math.PI;
            circle.style.strokeDasharray = `${circumference} ${circumference}`;
            circle.style.strokeDashoffset = circumference;
            
            updateDisplay();
            
            const orbit = document.getElementById('hamster-orbit');
            orbit.style.animationPlayState = 'paused';
            
            const hamster = document.querySelector('.hamster-container');
            hamster.classList.add('idle');
            hamster.classList.remove('running');
        }
        
        function updateDisplay() {
            const mins = Math.floor(timeLeft / 60);
            const secs = timeLeft % 60;
            document.querySelector('.timer-display').textContent = 
                `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
            
            const circle = document.getElementById('progress-circle');
            const radius = 125;
            const circumference = radius * 2 * Math.PI;
            const progress = (totalFocusSeconds - timeLeft) / totalFocusSeconds;
            circle.style.strokeDashoffset = circumference - progress * circumference;
        }
        
        function handleToggle() {
            if (isRunning) {
                pauseTimer();
            } else {
                startTimer();
            }
        }
        
        function startTimer() {
            isRunning = true;
            document.querySelector('.btn-main svg polygon').setAttribute('points', '18,12 18,36');
            document.querySelector('.btn-main svg polygon').setAttribute('fill', 'white');
            
            const hamster = document.querySelector('.hamster-container');
            hamster.classList.remove('idle');
            hamster.classList.add('running');
            
            const wheelSpokes = document.getElementById('wheel-spokes');
            wheelSpokes.classList.add('wheel-spokes-rotating');
            wheelSpokes.style.animationDuration = '1500s';
            
            const orbit = document.getElementById('hamster-orbit');
            orbit.style.animationPlayState = 'running';
            
            timer = setInterval(() => {
                if (timeLeft > 0) {
                    timeLeft--;
                    updateDisplay();
                } else {
                    completePhase();
                }
            }, 1000);
        }
        
        function pauseTimer() {
            isRunning = false;
            if (timer) clearInterval(timer);
            
            document.querySelector('.btn-main svg polygon').setAttribute('points', '18,12 38,24 18,36');
            
            const hamster = document.querySelector('.hamster-container');
            hamster.classList.remove('running');
            hamster.classList.add('idle');
            
            const wheelSpokes = document.getElementById('wheel-spokes');
            wheelSpokes.classList.remove('wheel-spokes-rotating');
            
            const orbit = document.getElementById('hamster-orbit');
            orbit.style.animationPlayState = 'paused';
        }
        
        function handleReset() {
            pauseTimer();
            timeLeft = totalFocusSeconds;
            updateDisplay();
            
            const hamster = document.querySelector('.hamster-container');
            hamster.classList.add('idle');
            hamster.classList.remove('running');
            
            const orbit = document.getElementById('hamster-orbit');
            orbit.style.animationPlayState = 'paused';
            orbit.style.transform = 'rotate(0deg)';
            
            const wheelSpokes = document.getElementById('wheel-spokes');
            wheelSpokes.style.animationDuration = '1500s';
            wheelSpokes.style.transform = 'rotate(0deg)';
        }
        
        function completePhase() {
            pauseTimer();
            const hamster = document.querySelector('.hamster-container');
            hamster.classList.add('idle');
            
            recordTomatoCompletion();
            
            document.getElementById('phase-complete-modal').style.display = 'flex';
        }
        
        function recordTomatoCompletion() {
            const today = new Date().toISOString().split('T')[0];
            const completions = JSON.parse(localStorage.getItem('pomodoro_completions') || '{}');
            if (!completions[today]) completions[today] = 0;
            completions[today]++;
            localStorage.setItem('pomodoro_completions', JSON.stringify(completions));
            
            const streak = JSON.parse(localStorage.getItem('pomodoro_streak') || '{"count":0,"lastDate":""}');
            const yesterday = new Date(Date.now() - 86400000).toISOString().split('T')[0];
            if (streak.lastDate === today) {
                // already recorded today
            } else if (streak.lastDate === yesterday) {
                streak.count++;
                streak.lastDate = today;
            } else {
                streak.count = 1;
                streak.lastDate = today;
            }
            localStorage.setItem('pomodoro_streak', JSON.stringify(streak));
        }
        
        function showInterruptModal() {
            document.getElementById('interrupt-modal').style.display = 'flex';
        }
        
        function hideInterruptModal() {
            document.getElementById('interrupt-modal').style.display = 'none';
        }
        
        function selectInterrupt(type) {
            const interruptions = JSON.parse(localStorage.getItem('pomodoro_interruptions') || '[]');
            const reasonInput = document.getElementById('interrupt-reason');
            const reason = reasonInput ? reasonInput.value.trim() : '';
            interruptions.push({
                type: type,
                reason: reason,
                time: new Date().toISOString()
            });
            localStorage.setItem('pomodoro_interruptions', JSON.stringify(interruptions));
            if (reasonInput) reasonInput.value = '';
            hideInterruptModal();
            showToast('已记录中断，继续加油哦~ 🐾');
        }
        
        function showToast(message) {
            const existingToast = document.querySelector('.toast-message');
            if (existingToast) existingToast.remove();
            
            const toast = document.createElement('div');
            toast.className = 'toast-message';
            toast.textContent = message;
            toast.style.cssText = `
                position: fixed;
                top: 80px;
                left: 50%;
                transform: translateX(-50%);
                background: var(--color-wisteria);
                color: white;
                padding: 12px 24px;
                border-radius: 20px;
                font-family: var(--font-family-display);
                font-size: 14px;
                z-index: 300;
                box-shadow: 0 4px 16px rgba(201,167,235,0.4);
                animation: toast-in 0.3s ease-out;
            `;
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.style.animation = 'toast-out 0.3s ease-in forwards';
                setTimeout(() => toast.remove(), 300);
            }, 2000);
        }
        
        function startBreak() {
            document.getElementById('phase-complete-modal').style.display = 'none';
            window.location.href = 'break-guide.html';
        }
        
        function skipBreak() {
            document.getElementById('phase-complete-modal').style.display = 'none';
            timeLeft = totalFocusSeconds;
            updateDisplay();
        }
        
        function openAiChat() {
            window.location.href = 'ai-chat.html';
        }
        
        function openPage(page) {
            window.location.href = page;
        }
        
        function renderHomeTasks() {
            const container = document.getElementById('home-task-list');
            const summary = document.getElementById('task-summary');
            const tasks = JSON.parse(localStorage.getItem('pomodoro_tasks') || '[]');
            const completed = tasks.filter(t => t.completed).length;
            const total = tasks.length;
            
            summary.textContent = `${completed}/${total} 已完成`;
            
            if (total === 0) {
                container.innerHTML = `
                    <div style="text-align: center; padding: 16px; color: var(--color-warm-gray); font-size: 13px;">
                        <svg viewBox="0 0 40 40" width="40" height="40" fill="none" style="margin-bottom: 8px;">
                            <circle cx="20" cy="22" r="10" fill="#E8D5F5"/>
                            <circle cx="16" cy="20" r="2" fill="#C9A7EB"/>
                            <circle cx="24" cy="20" r="2" fill="#C9A7EB"/>
                            <path d="M15 26 Q20 30 25 26" stroke="#C9A7EB" stroke-width="2" fill="none"/>
                        </svg>
                        <br>还没有任务，点击去任务页添加吧~
                    </div>
                `;
                return;
            }
            
            container.innerHTML = '';
            
            tasks.slice(0, 3).forEach(task => {
                const item = document.createElement('div');
                item.style.cssText = 'display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:rgba(255,255,255,0.5);border-radius:16px;cursor:pointer;transition:background 0.2s;';
                item.onmouseenter = function() { this.style.background = 'rgba(201, 167, 235, 0.15)'; };
                item.onmouseleave = function() { this.style.background = 'rgba(255, 255, 255, 0.5)'; };
                item.onclick = function() { openPage('task-plan.html'); };
                
                const checked = task.completed;
                const mintGreen = getComputedStyle(document.documentElement).getPropertyValue('--color-mint-green').trim() || '#B5EAD7';
                const lightPurple = getComputedStyle(document.documentElement).getPropertyValue('--color-light-purple').trim() || '#E8D5F5';
                const color = checked ? mintGreen : lightPurple;
                const check = checked ? '✓' : '';
                item.innerHTML = `
                    <div style="display:flex;align-items:center;gap:10px;flex:1;">
                        <div style="width:24px;height:24px;border-radius:50%;${checked ? 'background:'+color+';border:2px solid '+color+';color:white;display:flex;align-items:center;justify-content:center;font-weight:bold;font-size:14px;' : 'background:white;border:2px solid var(--color-light-purple);'}">${check}</div>
                        <div style="flex:1;">
                            <div style="font-size:14px;color:var(--color-deep-purple-gray);${checked ? 'text-decoration:line-through;color:var(--color-warm-gray);' : ''}">${task.title}</div>
                            <div style="font-size:11px;color:var(--color-warm-gray);display:flex;align-items:center;gap:8px;margin-top:2px;">
                                <span>🍅 ${task.tomatoes}</span>
                                <span>•</span>
                                <span>${'🐾'.repeat(task.commitment)}</span>
                            </div>
                        </div>
                    </div>
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="#C9A7EB">
                        <path d="M6 4L10 8L6 12" stroke="#C9A7EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                `;
                container.appendChild(item);
            });
            
            if (tasks.length > 3) {
                const more = document.createElement('div');
                more.style.cssText = 'text-align:center;padding:8px;color:#5A4E6B;font-size:12px;';
                more.textContent = `还有 ${tasks.length - 3} 个任务...`;
                container.appendChild(more);
            }
        }
        
        initHomeTimer();
        renderHomeTasks();
        
        // ===== Music Player with Web Audio API =====
        let audioCtx = null;
        let noiseNodes = [];
        let isMusicPlaying = false;
        let musicProgress = 0;
        let musicTimer = null;
        let musicDuration = 1800;
        let currentTrackIndex = 0;
        let localTrackName = '';
        let localAudioEl = null;
        let masterVolume = 0.7;
        
        const musicTracks = [
            { name: '雨声', icon: '🌧️', desc: '淅淅沥沥的白噪音', type: 'rain' },
            { name: '森林', icon: '🌲', desc: '鸟鸣与树叶沙沙', type: 'forest' },
            { name: '咖啡馆', icon: '☕', desc: '轻柔的背景人声', type: 'cafe' },
            { name: '壁炉', icon: '🔥', desc: '柴火噼啪作响', type: 'fireplace' },
            { name: '海浪', icon: '🌊', desc: '潮起潮落的声音', type: 'waves' },
        ];
        
        async function initAudioCtx() {
            try {
                if (!audioCtx) {
                    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                }
                if (audioCtx.state === 'suspended') {
                    await audioCtx.resume();
                }
                console.log('AudioContext state:', audioCtx.state);
                return audioCtx.state === 'running';
            } catch(e) {
                console.error('AudioContext init failed:', e);
                return false;
            }
        }
        
        // Aggressively init audio on any user interaction
        ['click', 'touchstart', 'touchend'].forEach(evt => {
            document.addEventListener(evt, function initAudioOnInteraction() {
                if (!audioCtx || audioCtx.state === 'suspended') {
                    initAudioCtx();
                }
            }, { once: false, passive: true });
        });
        
        function stopAllNoise() {
            noiseNodes.forEach(n => {
                try { n.stop(); } catch(e) {}
                try { n.disconnect(); } catch(e) {}
            });
            noiseNodes = [];
            if (localAudioEl) {
                localAudioEl.pause();
                localAudioEl = null;
            }
        }
        
        async function createNoise(type) {
            const ok = await initAudioCtx();
            if (!ok) return;
            stopAllNoise();
            
            const masterGain = audioCtx.createGain();
            masterGain.gain.value = masterVolume;
            masterGain.connect(audioCtx.destination);
            noiseNodes.push(masterGain);
            
            if (type === 'rain') createRainNoise(masterGain);
            else if (type === 'forest') createForestNoise(masterGain);
            else if (type === 'cafe') createCafeNoise(masterGain);
            else if (type === 'fireplace') createFireplaceNoise(masterGain);
            else if (type === 'waves') createWavesNoise(masterGain);
        }
        
        function createNoiseBuffer(duration) {
            const sampleRate = audioCtx.sampleRate;
            const length = Math.floor(sampleRate * duration);
            const buffer = audioCtx.createBuffer(1, length, sampleRate);
            const data = buffer.getChannelData(0);
            for (let i = 0; i < length; i++) {
                data[i] = Math.random() * 2 - 1;
            }
            return buffer;
        }

        // Helper: 创建一个柔和的噪声层（带滤波和增益）
        function makeNoiseLayer(masterGain, filterType, freq, q, gain) {
            const g = audioCtx.createGain();
            g.gain.value = gain;
            const f = audioCtx.createBiquadFilter();
            f.type = filterType; f.frequency.value = freq;
            if (q !== undefined) f.Q.value = q;
            const s = audioCtx.createBufferSource();
            s.buffer = createNoiseBuffer(10); s.loop = true;
            s.connect(f); f.connect(g); g.connect(masterGain);
            s.start(); noiseNodes.push(s, g, f);
            return { source: s, gain: g, filter: f };
        }

        function createRainNoise(masterGain) {
            // Layer 1: 高频雨声hiss (柔和版，去掉刺耳的4kHz共振)
            const layer1 = makeNoiseLayer(masterGain, 'highpass', 1800, undefined, 0.4);
            const notch = audioCtx.createBiquadFilter();
            notch.type = 'notch'; notch.frequency.value = 4200; notch.Q.value = 2;
            layer1.source.disconnect();
            layer1.source.connect(layer1.filter);
            layer1.filter.disconnect();
            layer1.filter.connect(notch);
            notch.connect(layer1.gain);
            noiseNodes.push(notch);

            // Layer 2: 中频雨声body (更柔和的bandpass)
            makeNoiseLayer(masterGain, 'bandpass', 700, 1.0, 0.28);

            // Layer 3: 低频底噪 (让雨声更厚重)
            makeNoiseLayer(masterGain, 'lowpass', 250, undefined, 0.12);

            // Layer 4: 柔和水滴音 (低音量、带envelope、频率下滑更自然)
            function drop() {
                if (!isMusicPlaying) return;
                const osc = audioCtx.createOscillator();
                osc.type = 'sine';
                const baseFreq = 420 + Math.random() * 380;
                osc.frequency.setValueAtTime(baseFreq * 1.4, audioCtx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(baseFreq, audioCtx.currentTime + 0.04);
                const g = audioCtx.createGain();
                g.gain.setValueAtTime(0, audioCtx.currentTime);
                g.gain.linearRampToValueAtTime(0.08, audioCtx.currentTime + 0.005);
                g.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.1);
                osc.connect(g); g.connect(masterGain);
                osc.start(); osc.stop(audioCtx.currentTime + 0.12);
                noiseNodes.push(osc, g);
            }
            const dropInterval = setInterval(() => {
                if (!isMusicPlaying) { clearInterval(dropInterval); return; }
                const count = Math.floor(Math.random() * 3) + 1;
                for (let i = 0; i < count; i++) setTimeout(drop, Math.random() * 300);
            }, 550);
            noiseNodes.push({ stop: () => clearInterval(dropInterval) });
        }

        function createForestNoise(masterGain) {
            // Layer 1: 主风声 (多层lowpass让风声更柔和)
            const windLayer = makeNoiseLayer(masterGain, 'lowpass', 480, undefined, 0.32);
            const windLayer2 = makeNoiseLayer(masterGain, 'lowpass', 850, undefined, 0.12);

            // LFO for wind variation (更慢更自然)
            const lfo = audioCtx.createOscillator();
            lfo.type = 'sine'; lfo.frequency.value = 0.13;
            const lfoG = audioCtx.createGain();
            lfoG.gain.value = 0.18;
            lfo.connect(lfoG); lfoG.connect(windLayer.gain.gain);
            lfoG.connect(windLayer2.gain.gain);
            lfo.start(); noiseNodes.push(lfo, lfoG);

            // Layer 2: 树叶沙沙声 (高频带通)
            makeNoiseLayer(masterGain, 'bandpass', 3500, 0.6, 0.06);

            // Layer 3: 自然鸟鸣 (带颤音+更长envelope)
            function chirp() {
                if (!isMusicPlaying) return;
                const osc = audioCtx.createOscillator();
                osc.type = 'triangle';
                const baseFreq = 1100 + Math.random() * 1500;
                osc.frequency.setValueAtTime(baseFreq, audioCtx.currentTime);
                osc.frequency.linearRampToValueAtTime(baseFreq * 1.25, audioCtx.currentTime + 0.08);
                osc.frequency.linearRampToValueAtTime(baseFreq * 0.85, audioCtx.currentTime + 0.18);

                // 颤音LFO
                const vib = audioCtx.createOscillator();
                vib.type = 'sine'; vib.frequency.value = 18 + Math.random() * 8;
                const vibG = audioCtx.createGain();
                vibG.gain.value = 25;
                vib.connect(vibG); vibG.connect(osc.frequency);
                vib.start(); vib.stop(audioCtx.currentTime + 0.25);

                const g = audioCtx.createGain();
                g.gain.setValueAtTime(0, audioCtx.currentTime);
                g.gain.linearRampToValueAtTime(0.08, audioCtx.currentTime + 0.02);
                g.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.25);
                osc.connect(g); g.connect(masterGain);
                osc.start(); osc.stop(audioCtx.currentTime + 0.25);
                noiseNodes.push(osc, g, vib, vibG);
            }
            const chirpInterval = setInterval(() => {
                if (!isMusicPlaying) { clearInterval(chirpInterval); return; }
                if (Math.random() < 0.3) chirp();
            }, 2200);
            noiseNodes.push({ stop: () => clearInterval(chirpInterval) });
        }

        function createCafeNoise(masterGain) {
            // Layer 1: 环境音 (多层lowpass让背景更柔和)
            makeNoiseLayer(masterGain, 'lowpass', 320, undefined, 0.3);
            makeNoiseLayer(masterGain, 'lowpass', 520, undefined, 0.1);

            // Layer 2: 低声喃喃 (formant-like filter模拟人声)
            makeNoiseLayer(masterGain, 'bandpass', 280, 0.7, 0.14);

            // Layer 3: 远处脚步声 (低频脉冲)
            function footstep() {
                if (!isMusicPlaying) return;
                const buf = audioCtx.createBuffer(1, Math.floor(audioCtx.sampleRate * 0.12), audioCtx.sampleRate);
                const d = buf.getChannelData(0);
                for (let i = 0; i < d.length; i++) {
                    d[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / d.length, 2);
                }
                const g = audioCtx.createGain();
                g.gain.value = 0.06;
                const f = audioCtx.createBiquadFilter();
                f.type = 'lowpass'; f.frequency.value = 180;
                const s = audioCtx.createBufferSource();
                s.buffer = buf; s.connect(f); f.connect(g); g.connect(masterGain);
                s.start(); s.stop(audioCtx.currentTime + 0.12);
                noiseNodes.push(s, g, f);
            }
            const footInterval = setInterval(() => {
                if (!isMusicPlaying) { clearInterval(footInterval); return; }
                if (Math.random() < 0.4) setTimeout(footstep, Math.random() * 200);
            }, 2000);
            noiseNodes.push({ stop: () => clearInterval(footInterval) });

            // Layer 4: 远处杯响 (柔和版，频率更低、音量更小)
            function clink() {
                if (!isMusicPlaying) return;
                const osc = audioCtx.createOscillator();
                osc.type = 'sine';
                osc.frequency.value = 1600 + Math.random() * 1200;
                const g = audioCtx.createGain();
                g.gain.setValueAtTime(0, audioCtx.currentTime);
                g.gain.linearRampToValueAtTime(0.05, audioCtx.currentTime + 0.01);
                g.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.3);
                osc.connect(g); g.connect(masterGain);
                osc.start(); osc.stop(audioCtx.currentTime + 0.3);
                noiseNodes.push(osc, g);
            }
            const clinkInterval = setInterval(() => {
                if (!isMusicPlaying) { clearInterval(clinkInterval); return; }
                if (Math.random() < 0.12) clink();
            }, 3500);
            noiseNodes.push({ stop: () => clearInterval(clinkInterval) });
        }

        function createFireplaceNoise(masterGain) {
            // Layer 1: 低频rumble
            const rumbleLayer = makeNoiseLayer(masterGain, 'lowpass', 180, undefined, 0.42);

            // LFO for flame flicker (更柔和)
            const lfo = audioCtx.createOscillator();
            lfo.type = 'sine'; lfo.frequency.value = 0.35;
            const lfoG = audioCtx.createGain();
            lfoG.gain.value = 0.22;
            lfo.connect(lfoG); lfoG.connect(rumbleLayer.gain.gain);
            lfo.start(); noiseNodes.push(lfo, lfoG);

            // Layer 2: 高频嘶嘶声 (火焰上方空气声)
            const hissLayer = makeNoiseLayer(masterGain, 'highpass', 3500, undefined, 0.08);
            const hissLfo = audioCtx.createOscillator();
            hissLfo.type = 'sine'; hissLfo.frequency.value = 0.6;
            const hissLfoG = audioCtx.createGain();
            hissLfoG.gain.value = 0.04;
            hissLfo.connect(hissLfoG); hissLfoG.connect(hissLayer.gain.gain);
            hissLfo.start(); noiseNodes.push(hissLfo, hissLfoG);

            // Layer 3: 自然噼啪声 (更长envelope、更柔和的bandpass)
            function crackle() {
                if (!isMusicPlaying) return;
                const buf = audioCtx.createBuffer(1, Math.floor(audioCtx.sampleRate * 0.1), audioCtx.sampleRate);
                const d = buf.getChannelData(0);
                for (let i = 0; i < d.length; i++) {
                    d[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / d.length, 1.5);
                }
                const g = audioCtx.createGain();
                g.gain.setValueAtTime(0, audioCtx.currentTime);
                g.gain.linearRampToValueAtTime(0.18, audioCtx.currentTime + 0.005);
                g.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.1);
                const f = audioCtx.createBiquadFilter();
                f.type = 'bandpass'; f.frequency.value = 2000 + Math.random() * 2000; f.Q.value = 2;
                const s = audioCtx.createBufferSource();
                s.buffer = buf; s.connect(f); f.connect(g); g.connect(masterGain);
                s.start(); s.stop(audioCtx.currentTime + 0.1);
                noiseNodes.push(s, g, f);
            }
            const crackleInterval = setInterval(() => {
                if (!isMusicPlaying) { clearInterval(crackleInterval); return; }
                const count = Math.floor(Math.random() * 3) + 1;
                for (let i = 0; i < count; i++) setTimeout(crackle, Math.random() * 200);
            }, 350);
            noiseNodes.push({ stop: () => clearInterval(crackleInterval) });
        }

        function createWavesNoise(masterGain) {
            // Layer 1: 深海rumble (主低频)
            const deepLayer = makeNoiseLayer(masterGain, 'lowpass', 220, undefined, 0.4);

            // 海浪LFO (更慢更自然 0.08Hz = 12秒周期)
            const lfo1 = audioCtx.createOscillator();
            lfo1.type = 'sine'; lfo1.frequency.value = 0.08;
            const lfo1G = audioCtx.createGain();
            lfo1G.gain.value = 0.35;
            lfo1.connect(lfo1G); lfo1G.connect(deepLayer.gain.gain);
            lfo1.start(); noiseNodes.push(lfo1, lfo1G);

            // Layer 2: 中频海水声
            const midLayer = makeNoiseLayer(masterGain, 'bandpass', 600, 0.5, 0.15);
            const lfoMid = audioCtx.createOscillator();
            lfoMid.type = 'sine'; lfoMid.frequency.value = 0.08;
            const lfoMidG = audioCtx.createGain();
            lfoMidG.gain.value = 0.12;
            lfoMid.connect(lfoMidG); lfoMidG.connect(midLayer.gain.gain);
            lfoMid.start(); noiseNodes.push(lfoMid, lfoMidG);

            // Layer 3: 泡沫声 (高频hiss，跟随海浪)
            const foamLayer = makeNoiseLayer(masterGain, 'highpass', 1800, undefined, 0.18);
            const lfo2 = audioCtx.createOscillator();
            lfo2.type = 'sine'; lfo2.frequency.value = 0.08;
            const lfo2G = audioCtx.createGain();
            lfo2G.gain.value = 0.15;
            lfo2.connect(lfo2G); lfo2G.connect(foamLayer.gain.gain);
            lfo2.start(); noiseNodes.push(lfo2, lfo2G);

            // Layer 4: 远处微风 (让海浪场景更立体)
            makeNoiseLayer(masterGain, 'lowpass', 400, undefined, 0.06);
        }
        
        function updateMusicUI() {
            const track = musicTracks[currentTrackIndex];
            document.getElementById('music-title').textContent = track.icon + ' ' + track.name;
            document.getElementById('music-desc').textContent = track.desc;
            document.getElementById('music-duration').textContent = formatTime(musicDuration);
            updateMusicProgress();
        }
        
        function formatTime(seconds) {
            const m = Math.floor(seconds / 60);
            const s = Math.floor(seconds % 60);
            return `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
        }
        
        async function toggleMusic() {
            try {
                if (isMusicPlaying) {
                    isMusicPlaying = false;
                    const icon = document.getElementById('music-play-icon');
                    icon.innerHTML = '<polygon points="5,2 5,14 13,8" fill="white"/>';
                    document.querySelector('.music-bar').classList.remove('playing');
                    stopAllNoise();
                    clearInterval(musicTimer);
                    musicTimer = null;
                    showToast('已暂停 ⏸️');
                } else {
                    const icon = document.getElementById('music-play-icon');
                    icon.innerHTML = '<circle cx="8" cy="8" r="6" fill="none" stroke="white" stroke-width="2" stroke-dasharray="30 10"><animateTransform attributeName="transform" type="rotate" from="0 8 8" to="360 8 8" dur="1s" repeatCount="indefinite"/></circle>';
                    
                    const ok = await initAudioCtx();
                    if (!ok) {
                        icon.innerHTML = '<polygon points="5,2 5,14 13,8" fill="white"/>';
                        showToast('播放失败，请再点一次试试~ 🐾');
                        return;
                    }
                    
                    await createNoise(musicTracks[currentTrackIndex].type);
                    document.querySelector('.music-bar').classList.add('playing');
                    isMusicPlaying = true;
                    icon.innerHTML = '<rect x="4" y="2" width="3" height="12" fill="white"/><rect x="9" y="2" width="3" height="12" fill="white"/>';
                    musicProgress = 0;
                    updateMusicProgress();
                    musicTimer = setInterval(() => {
                        musicProgress++;
                        updateMusicProgress();
                        if (musicProgress >= musicDuration) {
                            nextTrack();
                        }
                    }, 1000);
                    showToast('正在播放: ' + musicTracks[currentTrackIndex].name + ' 🎵');
                }
            } catch(e) {
                console.error('白噪音播放失败:', e);
                isMusicPlaying = false;
                const icon = document.getElementById('music-play-icon');
                icon.innerHTML = '<polygon points="5,2 5,14 13,8" fill="white"/>';
                document.querySelector('.music-bar').classList.remove('playing');
                stopAllNoise();
                clearInterval(musicTimer);
                musicTimer = null;
                showToast('播放失败，请再点一次试试~ 🐾');
            }
        }
        
        function updateMusicProgress() {
            const pct = musicDuration > 0 ? (musicProgress / musicDuration) * 100 : 0;
            document.getElementById('music-fill').style.width = pct + '%';
            document.getElementById('music-thumb').style.left = pct + '%';
            document.getElementById('music-current').textContent = formatTime(musicProgress);
        }
        
        function seekMusic(e) {
            const slider = e.currentTarget;
            const rect = slider.getBoundingClientRect();
            const pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
            musicProgress = Math.floor(pct * musicDuration);
            updateMusicProgress();
        }
        
        async function prevTrack() {
            currentTrackIndex = (currentTrackIndex - 1 + musicTracks.length) % musicTracks.length;
            musicProgress = 0;
            updateMusicUI();
            if (isMusicPlaying) {
                await createNoise(musicTracks[currentTrackIndex].type);
            }
        }
        
        async function nextTrack() {
            currentTrackIndex = (currentTrackIndex + 1) % musicTracks.length;
            musicProgress = 0;
            updateMusicUI();
            if (isMusicPlaying) {
                await createNoise(musicTracks[currentTrackIndex].type);
            }
        }
        
        function toggleMusicList() {
            const list = document.getElementById('music-track-list');
            const isVisible = list.style.display === 'flex';
            list.style.display = isVisible ? 'none' : 'flex';
            if (!isVisible) {
                list.innerHTML = '';
                musicTracks.forEach((track, index) => {
                    const item = document.createElement('div');
                    item.style.cssText = 'display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:14px;cursor:pointer;font-size:13px;color:#3D334A;transition:background 0.2s;';
                    if (index === currentTrackIndex) {
                        item.style.background = 'rgba(201,167,235,0.3)';
                        item.style.fontWeight = 'bold';
                    }
                    item.innerHTML = `
                        <span style="font-size:18px;">${track.icon}</span>
                        <span style="flex:1;">${track.name}</span>
                        <span style="font-size:11px;color:var(--color-warm-gray);">${track.desc}</span>
                    `;
                    item.onclick = async function() {
                        currentTrackIndex = index;
                        musicProgress = 0;
                        updateMusicUI();
                        list.style.display = 'none';
                        if (isMusicPlaying) {
                            await createNoise(musicTracks[currentTrackIndex].type);
                        }
                    };
                    list.appendChild(item);
                });
            }
        }
        
        function handleLocalMusic(e) {
            const file = e.target.files[0];
            if (file) {
                stopAllNoise();
                clearInterval(musicTimer);
                localAudioEl = new Audio(URL.createObjectURL(file));
                localAudioEl.loop = true;
                localTrackName = file.name.replace(/\.[^/.]+$/, '');
                document.getElementById('music-title').textContent = '🎵 ' + localTrackName;
                document.getElementById('music-desc').textContent = '本地音乐';
                if (isMusicPlaying) {
                    localAudioEl.play();
                    localAudioEl.addEventListener('loadedmetadata', () => {
                        musicDuration = Math.floor(localAudioEl.duration) || 1800;
                        musicProgress = 0;
                        updateMusicUI();
                    });
                }
            }
            e.target.value = '';
        }
        
        // ===== Onboarding Modal Logic =====
        let onboardingCurrentStep = 1;
        const onboardingTotalSteps = 3;
        
        function initOnboarding() {
            const done = localStorage.getItem('pomodoro_onboarding_done');
            if (!done) {
                setTimeout(function() {
                    document.getElementById('onboarding-overlay').classList.add('active');
                    document.body.style.overflow = 'hidden';
                }, 300);
            }
        }
        
        function onboardingGoToStep(step) {
            // 更新步骤
            document.querySelectorAll('.onboarding-step').forEach(function(el) {
                el.classList.remove('active');
            });
            document.querySelector('.onboarding-step[data-step="' + step + '"]').classList.add('active');
            
            // 更新指示圆点
            document.querySelectorAll('.onboarding-dot').forEach(function(el) {
                el.classList.remove('active');
            });
            document.querySelector('.onboarding-dot[data-dot="' + step + '"]').classList.add('active');
            
            // 更新上一步按钮可见性
            const prevBtn = document.getElementById('onboarding-prev');
            if (step === 1) {
                prevBtn.classList.remove('show');
            } else {
                prevBtn.classList.add('show');
            }
            
            // 更新跳过按钮文字
            const skipBtn = document.getElementById('onboarding-skip');
            if (step === onboardingTotalSteps) {
                skipBtn.style.display = 'none';
            } else {
                skipBtn.style.display = 'block';
            }
            
            // 聚焦输入框
            if (step === 2) {
                setTimeout(function() {
                    const input = document.getElementById('onboarding-goal-input');
                    if (input) input.focus();
                }, 400);
            }
            
            onboardingCurrentStep = step;
        }
        
        function onboardingNext() {
            if (onboardingCurrentStep < onboardingTotalSteps) {
                // 如果当前是步骤2，保存目标
                if (onboardingCurrentStep === 2) {
                    const goalInput = document.getElementById('onboarding-goal-input');
                    const goal = goalInput ? goalInput.value.trim() : '';
                    if (goal) {
                        // 保存到今日目标，写入任务列表
                        const tasks = JSON.parse(localStorage.getItem('pomodoro_tasks') || '[]');
                        // 检查是否已有同名任务，避免重复
                        const exists = tasks.some(function(t) { return t.title === goal; });
                        if (!exists) {
                            tasks.push({
                                id: Date.now().toString(),
                                title: goal,
                                completed: false,
                                tomatoes: 0,
                                commitment: 1,
                                createdAt: new Date().toISOString()
                            });
                            localStorage.setItem('pomodoro_tasks', JSON.stringify(tasks));
                        }
                    }
                }
                onboardingGoToStep(onboardingCurrentStep + 1);
            }
        }
        
        function onboardingPrev() {
            if (onboardingCurrentStep > 1) {
                onboardingGoToStep(onboardingCurrentStep - 1);
            }
        }
        
        function onboardingFinish() {
            // 保存目标（如果步骤2有输入但未点击下一步）
            const goalInput = document.getElementById('onboarding-goal-input');
            if (goalInput) {
                const goal = goalInput.value.trim();
                if (goal) {
                    const tasks = JSON.parse(localStorage.getItem('pomodoro_tasks') || '[]');
                    const exists = tasks.some(function(t) { return t.title === goal; });
                    if (!exists) {
                        tasks.push({
                            id: Date.now().toString(),
                            title: goal,
                            completed: false,
                            tomatoes: 0,
                            commitment: 1,
                            createdAt: new Date().toISOString()
                        });
                        localStorage.setItem('pomodoro_tasks', JSON.stringify(tasks));
                    }
                }
            }
            
            // 标记引导已完成
            localStorage.setItem('pomodoro_onboarding_done', 'true');
            
            // 关闭弹窗
            document.getElementById('onboarding-overlay').classList.remove('active');
            document.body.style.overflow = '';
            
            // 刷新任务列表
            if (typeof renderHomeTasks === 'function') {
                renderHomeTasks();
            }
        }
        
        // 页面加载时初始化引导
        initOnboarding();
    </script>
</body>
