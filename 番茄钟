            exerciseTotalSeconds = 15;
            isExercisePaused = false;
            updateExerciseDisplay();
            startExerciseCountdown();
        }
        
        function updateExerciseDisplay() {
            const ex = exercises[currentExercise];
            const container = document.getElementById('stretch-svg');
            
            // 平滑切换过渡
            container.classList.add('switching');
            setTimeout(() => {
                container.innerHTML = ex.svg;
                container.classList.remove('switching');
            }, 180);
            
            document.getElementById('exercise-instruction').textContent = ex.instruction;
            document.getElementById('exercise-detail').textContent = ex.detail;
            document.getElementById('exercise-countdown').textContent = exerciseSeconds;
            
            const dots = document.querySelectorAll('#exercise-dots .step-dot');
            dots.forEach((dot, i) => {
                dot.classList.toggle('active', i === currentExercise);
            });
            
            updateProgressRing();
        }
        
        function updateProgressRing() {
            const ring = document.getElementById('progress-fg');
            if (!ring) return;
            const progress = exerciseTotalSeconds > 0 ? (exerciseTotalSeconds - exerciseSeconds) / exerciseTotalSeconds : 0;
            const offset = progressCircumference * (1 - progress);
            ring.style.strokeDashoffset = offset;
        }
        
        function startExerciseCountdown() {
            clearInterval(exerciseCountdown);
            exerciseCountdown = setInterval(() => {
                if (isExercisePaused) return;
                if (exerciseSeconds > 0) {
                    exerciseSeconds--;
                    document.getElementById('exercise-countdown').textContent = exerciseSeconds;
                    updateProgressRing();
                } else {
                    nextExercise();
                }
            }, 1000);
        }
        
        function nextExercise() {
            currentExercise = (currentExercise + 1) % exercises.length;
            exerciseSeconds = 15;
            exerciseTotalSeconds = 15;
            updateExerciseDisplay();
            clearInterval(exerciseTimer);
            startExerciseCountdown();
        }
        
        function prevExercise() {
            currentExercise = (currentExercise - 1 + exercises.length) % exercises.length;
            exerciseSeconds = 15;
            exerciseTotalSeconds = 15;
            updateExerciseDisplay();
            clearInterval(exerciseTimer);
            startExerciseCountdown();
        }
        
        function toggleExercisePause() {
            isExercisePaused = !isExercisePaused;
            const icon = document.getElementById('exercise-pause-icon');
            const wrapper = document.querySelector('.hamster-stretch');
            if (isExercisePaused) {
                icon.innerHTML = '<polygon points="4,2 4,14 13,8" fill="white"/>';
                if (wrapper) wrapper.style.animationPlayState = 'paused';
            } else {
                icon.innerHTML = '<rect x="3" y="2" width="4" height="12" fill="white"/><rect x="9" y="2" width="4" height="12" fill="white"/>';
                if (wrapper) wrapper.style.animationPlayState = 'running';
            }
        }
        
        function selectRestType(el) {
            document.querySelectorAll('.rest-card').forEach(card => {
                card.classList.remove('selected');
            });
            el.classList.add('selected');
        }
        
        function skipBreak() {
            clearInterval(countdownTimer);
            clearInterval(exerciseTimer);
            clearInterval(exerciseCountdown);
