                    <line x1="160" y1="38" x2="160" y2="282" stroke="#FFD0D6" stroke-width="0.8" stroke-linecap="round" opacity="0.15" transform="rotate(60 160 160)"/>
                    <line x1="160" y1="38" x2="160" y2="282" stroke="#FFD0D6" stroke-width="0.8" stroke-linecap="round" opacity="0.15" transform="rotate(90 160 160)"/>
                    <line x1="160" y1="38" x2="160" y2="282" stroke="#FFD0D6" stroke-width="0.8" stroke-linecap="round" opacity="0.15" transform="rotate(120 160 160)"/>
