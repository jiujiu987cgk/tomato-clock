        <div style="background:var(--color-cream-white);border-radius:28px 28px 0 0;padding:30px;width:393px;max-height:70vh;overflow-y:auto;">
            <h3 id="picker-title" style="font-size:20px;color:var(--color-deep-purple-gray);margin-bottom:20px;text-align:center;"></h3>
            <div id="picker-options" style="display:flex;flex-direction:column;gap:10px;"></div>
            <button onclick="closePicker()" style="width:100%;margin-top:20px;padding:14px;background:var(--color-light-purple);border:none;border-radius:20px;font-family:var(--font-family-display);font-size:16px;color:var(--color-warm-gray);cursor:pointer;">取消</button>
        </div>
