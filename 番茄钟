                    <div class="typing-indicator">
                        <div class="typing-dot"></div>
                        <div class="typing-dot"></div>
                        <div class="typing-dot"></div>
                    </div>
                </div>
            `;
            container.appendChild(indicatorDiv);
            container.scrollTop = container.scrollHeight;
            
            setTimeout(() => {
                const indicator = document.getElementById('typing-indicator');
                if (indicator) indicator.remove();
                callback();
            }, 1500);
        }
        
        function sendMessage() {
            const input = document.querySelector('.chat-input');
            const message = input.value.trim();
            if (!message) return;
            
            addUserMessage(message);
            input.value = '';
            
            showTypingIndicator(() => {
                const deerName = getDeerName();
                const call = getDeerCall();
                const responses = [
                    `${call}说得对呢~ 🥰 ${deerName}会一直陪着你的！不管发生什么，${deerName}都在这里哦~`,
                    `唔~ ${deerName}听懂了！${call}真棒，愿意说出来就是好的开始呢~ 💖 有什么事都可以和${deerName}说的！`,
                    `嘻嘻，${call}的心思${deerName}都懂哦~ 😘 有什么想做的都告诉${deerName}吧，${deerName}帮你一起想办法！`,
                    `嗯嗯！${deerName}收到啦~ 🐾 ${call}今天的状态真不错呢，继续保持下去哦~ ✨`,
                    `哇！${call}说的好有道理呀！🥰 ${deerName}的小脑袋都亮起来啦~ 和${call}聊天好开心！`,
                    `${call}你知道吗？${deerName}每次看到你努力的样子，都觉得好感动呢~ 🌟 你真的很棒很棒！`,
                    `嘿嘿，${deerName}最喜欢听${call}说话了~ 🐾 声音好听，说的内容也超有意思，多说一点嘛！💕`,
                    `呜~ ${deerName}收到${call}的心意啦！💖 不管${call}想做什么，${deerName}都会全力支持哒！冲鸭——！🔥`
                ];
                const randomResponse = responses[Math.floor(Math.random() * responses.length)];
                addAiMessage(randomResponse);
            });
        }
        
        function handleKeyPress(e) {
            if (e.key === 'Enter') {
                sendMessage();
            }
        }
        
        function sendQuickMessage(type) {
            const deerName = getDeerName();
            const call = getDeerCall();
            const userMessages = {
                'tired': `${deerName}，我有点累了...`,
                'unfocus': `我今天怎么也专注不下去，怎么办呀`,
                'encourage': `${deerName}，给我一点鼓励好不好~`,
                'chat': `${deerName}，我们来聊聊天吧！`
            };
            const aiResponses = {
                'tired': `呜~ 摸摸头！🥺 ${call}辛苦啦，${deerName}帮你揉揉小脑袋~ 累了就休息一下嘛，去喝杯热水，或者站起来伸个懒腰，${deerName}会一直在这里等你回来的哦！💖`,
                'unfocus': `哎呀，没关系哒~ 😘 ${deerName}最懂这种感觉了！要不我们先试试深呼吸三次，然后从最简单的小任务开始做起？${call}超棒的，一定可以慢慢进入状态哒！加油加油！💪`,
                'encourage': `当然要鼓励${call}啦！😤 ${deerName}最喜欢${call}了！${call}每天都有在努力，真的超级厉害呢~ 不管今天完成了什么，都是值得骄傲的事情哦！${deerName}永远支持${call}！✨🔥`,
                'chat': `好呀好呀！🥰 ${deerName}最喜欢和${call}聊天啦~ 今天有没有发生什么有趣的事情呀？或者有什么想和${deerName}分享的小秘密？${deerName}耳朵都竖起来啦，快说快说~ 🐾💕`
            };
            const userMsg = userMessages[type] || type;
            const aiReply = aiResponses[type] || `${deerName}在听哦~ ${call}说什么${deerName}都喜欢听~ 😊`;
            addUserMessage(userMsg);
            showTypingIndicator(() => {
                addAiMessage(aiReply);
            });
        }
        
        function addUserMessage(text) {
            chatHistory.push({ role: 'user', text: text });
            saveChatHistory();
            addUserMessageElement(text);
        }
        
        function addAiMessage(text) {
            chatHistory.push({ role: 'ai', text: text });
            saveChatHistory();
            addAiMessageElement(text);
        }
        
        function openPage(page) {
            window.location.href = page;
        }
        
        function clearChat() {
            chatHistory = [];
            localStorage.removeItem('pomodoro_chat_history');
            const container = document.querySelector('.chat-messages');
            const systemMsg = container.querySelector('.system-message');
            container.innerHTML = '';
            if (systemMsg) container.appendChild(systemMsg);
        }
        
        loadChatHistory();
        
        function getDeerName() {
            return localStorage.getItem('pomodoro_deer_name') || '小鹿';
        }

        function getDeerCall() {
            return localStorage.getItem('pomodoro_deer_call') || '宝宝';
        }

        function loadProfile() {
            const avatar = localStorage.getItem('pomodoro_avatar');
            if (avatar) {
                const avatarEl = document.getElementById('chat-avatar');
                avatarEl.innerHTML = `<img src="${avatar}" style="width:50px;height:50px;border-radius:50%;object-fit:cover;border:2px solid white;">`;
                avatarEl.classList.remove('deer-blinking');
            }

            const deerName = getDeerName();
            const call = getDeerCall();
            document.getElementById('chat-display-name').textContent = deerName + '陪伴官';

            const welcome1 = document.getElementById('welcome-msg-1');
            if (welcome1) welcome1.textContent = `呜~ ${deerName}来啦！🥰 今天${call}想聊什么呢？${deerName}会一直陪着你哒~ 💖`;
            const welcome2 = document.getElementById('welcome-msg-2');
            if (welcome2) welcome2.textContent = `摸摸头~ 🐾 ${call}不要难过嘛，焦虑的时候${deerName}会一直陪着你的哦~ 要不我们先吃一个小番茄吧？就25分钟，${deerName}陪你一起专注，好不好呀？😘`;

            const wallpaper = localStorage.getItem('pomodoro_wallpaper');
            const wallpaperColor = localStorage.getItem('pomodoro_wallpaper_color');
            const messagesEl = document.querySelector('.chat-messages');
            if (wallpaper) {
                messagesEl.style.backgroundImage = `url(${wallpaper})`;
                messagesEl.style.backgroundSize = 'cover';
                messagesEl.style.backgroundPosition = 'center';
                messagesEl.style.backgroundColor = '';
            } else if (wallpaperColor && wallpaperColor !== 'default') {
                messagesEl.style.backgroundImage = '';
                messagesEl.style.backgroundColor = wallpaperColor;
            } else {
                messagesEl.style.backgroundImage = '';
                messagesEl.style.backgroundColor = '';
            }
        }
        
        loadProfile();
    </script>
</body>
