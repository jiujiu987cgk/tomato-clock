    <script>
        let tomatoValue = 1;
        let tasks = [];
        let pawRating = 3;
        
        function loadTasks() {
            const saved = localStorage.getItem('pomodoro_tasks');
            tasks = saved ? JSON.parse(saved) : getDefaultTasks();
            renderTasks();
            
            const savedDump = localStorage.getItem('pomodoro_brain_dump');
            if (savedDump) {
                document.querySelector('.brain-dump textarea').value = savedDump;
            }
            
            updatePlanBDisplay();
        }
        
        function getDefaultTasks() {
            return [
                { id: '1', title: '完成项目设计稿', tomatoes: 3, commitment: 3, completed: false, createdAt: Date.now() },
                { id: '2', title: '整理会议记录', tomatoes: 1, commitment: 2, completed: true, createdAt: Date.now() },
                { id: '3', title: '学习新框架', tomatoes: 2, commitment: 4, completed: false, createdAt: Date.now() }
            ];
        }
        
        function saveTasks() {
            localStorage.setItem('pomodoro_tasks', JSON.stringify(tasks));
        }
        
        function renderTasks() {
            const container = document.querySelector('.scrollable-content');
            const existingCards = container.querySelectorAll('.task-card');
            existingCards.forEach(card => card.remove());
            
            tasks.forEach((task, index) => {
                const card = createTaskCard(task, index);
                const brainDump = container.querySelector('.brain-dump');
                container.insertBefore(card, brainDump);
            });
        }
        
        function createTaskCard(task, index) {
            const card = document.createElement('div');
            card.className = 'task-card';
            
            const checkedClass = task.completed ? ' checked' : '';
            const checkDisplay = task.completed ? 'block' : 'none';
            const titleStyle = task.completed ? 'text-decoration: line-through; color: var(--color-warm-gray);' : '';
            
            card.innerHTML = `
                <div class="task-checkbox${checkedClass}" onclick="toggleTaskByIndex(${index})">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="#3D334A" style="display: ${checkDisplay};">
                        <path d="M3 7L6 10L13 4" stroke="#3D334A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <div class="task-content">
                    <div class="task-title" style="${titleStyle}">${task.title}</div>
                    <div class="task-meta">
                        <div class="tomato-count">
                            <button onclick="changeTomato(event, ${index}, -1)">-</button>
                            <svg width="20" height="20" viewBox="0 0 20 20" fill="#FF6B6B">
                                <circle cx="10" cy="11" r="6" fill="#FF6B6B"/>
                                <path d="M10 5L9 2L11 2Z" fill="#B5EAD7"/>
                            </svg>
                            <span style="font-size: 12px; color: var(--color-warm-gray);">${task.tomatoes}</span>
                            <button onclick="changeTomato(event, ${index}, 1)">+</button>
                        </div>
                        <div class="paw-rating">
                            ${generatePawIcons(task.commitment)}
                        </div>
                    </div>
                </div>
                <button onclick="deleteTask(event, ${index})" style="background:none;border:none;cursor:pointer;padding:4px;flex-shrink:0;opacity:0.5;transition:opacity 0.2s;" onmouseenter="this.style.opacity='1'" onmouseleave="this.style.opacity='0.5'">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="#FF6B6B">
                        <line x1="4" y1="4" x2="14" y2="14" stroke="#FF6B6B" stroke-width="2" stroke-linecap="round"/>
                        <line x1="14" y1="4" x2="4" y2="14" stroke="#FF6B6B" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                </button>
            `;
            return card;
        }
        
        function generatePawIcons(count) {
            let html = '';
            for (let i = 0; i < 5; i++) {
                const filled = i < count ? 'filled' : 'empty';
                html += `<svg class="paw-icon ${filled}" viewBox="0 0 16 16">
                    <circle cx="8" cy="8" r="4" fill="#C9A7EB"/>
                    <circle cx="4" cy="6" r="2" fill="#C9A7EB"/>
                    <circle cx="12" cy="6" r="2" fill="#C9A7EB"/>
                    <circle cx="4" cy="10" r="2" fill="#C9A7EB"/>
                    <circle cx="12" cy="10" r="2" fill="#C9A7EB"/>
                </svg>`;
            }
            return html;
        }
        
        function toggleTaskByIndex(index) {
            tasks[index].completed = !tasks[index].completed;
            saveTasks();
            renderTasks();
        }
        
        function changeTomato(e, index, delta) {
            e.stopPropagation();
            const newCount = tasks[index].tomatoes + delta;
            if (newCount >= 1 && newCount <= 10) {
                tasks[index].tomatoes = newCount;
                saveTasks();
                renderTasks();
            }
        }
        
        function deleteTask(e, index) {
            e.stopPropagation();
            tasks.splice(index, 1);
            saveTasks();
            renderTasks();
        }
        
        function openAddTaskModal() {
            const savedRating = localStorage.getItem('pomodoro_paw_rating');
            if (savedRating) {
                pawRating = parseInt(savedRating);
                const container = document.querySelector('#add-task-modal .paw-rating');
                const paws = container.querySelectorAll('.paw-icon');
                paws.forEach((paw, index) => {
                    if (index < pawRating) {
                        paw.classList.remove('empty');
                        paw.classList.add('filled');
                    } else {
                        paw.classList.remove('filled');
                        paw.classList.add('empty');
                    }
                });
            }
            document.getElementById('add-task-modal').classList.add('active');
        }
        
        function closeAddTaskModal() {
            document.getElementById('add-task-modal').classList.remove('active');
        }
        
        function adjustTomatoInput(delta) {
            tomatoValue = Math.max(1, Math.min(10, tomatoValue + delta));
            document.getElementById('tomato-input-value').textContent = tomatoValue;
        }
        
        function setPawRating(el, rating) {
            pawRating = rating;
            const container = el.parentElement;
            const paws = container.querySelectorAll('.paw-icon');
            
            paws.forEach((paw, index) => {
                if (index < rating) {
                    paw.classList.remove('empty');
                    paw.classList.add('filled');
                } else {
                    paw.classList.remove('filled');
                    paw.classList.add('empty');
                }
            });
            
            localStorage.setItem('pomodoro_paw_rating', rating);
        }
        
        function submitTask() {
            const nameInput = document.getElementById('task-name');
            const title = nameInput.value.trim();
            if (!title) return;
            
            const newTask = {
                id: Date.now().toString(),
                title: title,
                tomatoes: tomatoValue,
                commitment: pawRating,
                completed: false,
                createdAt: Date.now()
            };
            
            tasks.push(newTask);
            saveTasks();
            renderTasks();
            
            nameInput.value = '';
            tomatoValue = 1;
            document.getElementById('tomato-input-value').textContent = '1';
            closeAddTaskModal();
        }
        
        function openPlanBModal() {
            document.getElementById('planb-modal').style.display = 'flex';
            const saved = localStorage.getItem('pomodoro_planb');
            if (saved) {
                const planb = JSON.parse(saved);
                document.getElementById('if-condition').value = planb.if || '';
                document.getElementById('then-action').value = planb.then || '';
            }
        }
        
        function closePlanBModal() {
            document.getElementById('planb-modal').style.display = 'none';
        }
        
        function savePlanB() {
            const ifCond = document.getElementById('if-condition').value.trim();
            const thenAct = document.getElementById('then-action').value.trim();
            if (ifCond && thenAct) {
                localStorage.setItem('pomodoro_planb', JSON.stringify({ if: ifCond, then: thenAct }));
                updatePlanBDisplay();
            }
            closePlanBModal();
        }
        
        function updatePlanBDisplay() {
            const saved = localStorage.getItem('pomodoro_planb');
            const display = document.getElementById('planb-display');
            if (saved) {
                const planb = JSON.parse(saved);
                display.innerHTML = '如果 ' + planb.if + '<br>那么 ' + planb.then;
            } else {
                display.textContent = '准备好应对突发状况了吗？';
            }
        }
        
        function openPage(page) {
            window.location.href = page;
        }
        
        function saveBrainDump() {
            const textarea = document.querySelector('.brain-dump textarea');
            localStorage.setItem('pomodoro_brain_dump', textarea.value);
        }
        
        loadTasks();
    </script>
</body>
</html>

