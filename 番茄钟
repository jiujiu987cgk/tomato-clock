                        <g transform="translate(11,18) scale(0.35)"><polygon points="0,-5 1.5,-1.5 5,-1.5 2.5,1 3.5,5 0,2.5 -3.5,5 -2.5,1 -5,-1.5 -1.5,-1.5" fill="#FFD700" opacity="0.9"/></g>
