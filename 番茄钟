    <script src="assets/js/common.js"></script>
    <script>
        const defaultSettings = {
            focusDuration: 25,
            breakDuration: 5,
            dailyGoal: 8,
            soundEnabled: true,
            notifyEnabled: true,
            dailyRemindEnabled: false
        };
        
        let settings = {};
        let pickerTarget = null;
        
        function loadSettings() {
            const saved = localStorage.getItem('pomodoro_settings');
            settings = saved ? JSON.parse(saved) : {...defaultSettings};
            if (!saved) saveSettings();
            applySettings();
        }
        
        function saveSettings() {
            localStorage.setItem('pomodoro_settings', JSON.stringify(settings));
        }
        
        function applySettings() {
            document.querySelectorAll('.setting-item').forEach(item => {
                const titleEl = item.querySelector('.setting-title');
                if (!titleEl) return;
                const title = titleEl.textContent.trim();
                
                if (title === '专注时长') {
                    item.querySelector('.setting-desc').textContent = `默认 ${settings.focusDuration} 分钟`;
                } else if (title === '休息时长') {
                    item.querySelector('.setting-desc').textContent = `默认 ${settings.breakDuration} 分钟`;
                } else if (title === '每日目标') {
                    item.querySelector('.setting-desc').textContent = `默认 ${settings.dailyGoal} 个番茄`;
                } else if (title === '番茄结束提醒') {
                    toggleSwitch(item, settings.notifyEnabled);
                } else if (title === '声音提醒') {
                    toggleSwitch(item, settings.soundEnabled);
                } else if (title === '每日目标提醒') {
                    toggleSwitch(item, settings.dailyRemindEnabled);
                }
            });
        }
        
        function toggleSwitch(el, state) {
            const toggle = el.querySelector('.toggle-switch');
            if (state) toggle.classList.add('active');
            else toggle.classList.remove('active');
        }
        
        function toggleSetting(el) {
            const toggle = el.querySelector('.toggle-switch');
            toggle.classList.toggle('active');
            const isActive = toggle.classList.contains('active');
            const title = el.querySelector('.setting-title').textContent.trim();
            
            if (title === '番茄结束提醒') {
                settings.notifyEnabled = isActive;
            } else if (title === '声音提醒') {
                settings.soundEnabled = isActive;
            } else if (title === '每日目标提醒') {
                settings.dailyRemindEnabled = isActive;
            }
            saveSettings();
        }
        
        function openPicker(el) {
            const title = el.querySelector('.setting-title').textContent.trim();
            pickerTarget = title;
            
            document.getElementById('picker-title').textContent = '选择' + title;
            const container = document.getElementById('picker-options');
            container.innerHTML = '';
            
            let options = [];
            let currentValue = '';
            
            if (title === '专注时长') {
                options = [15, 20, 25, 30, 45, 60];
                currentValue = settings.focusDuration + '分钟';
            } else if (title === '休息时长') {
                options = [3, 5, 10, 15];
                currentValue = settings.breakDuration + '分钟';
            } else if (title === '每日目标') {
                options = [4, 6, 8, 10, 12];
                currentValue = settings.dailyGoal + '个';
            }
            
            options.forEach(opt => {
                const btn = document.createElement('button');
                btn.style.cssText = 'width:100%;padding:16px;background:var(--color-cream-yellow);border:2px solid var(--color-light-purple);border-radius:16px;font-family:var(--font-family-display);font-size:16px;color:var(--color-deep-purple-gray);cursor:pointer;transition:all 0.2s;';
                btn.textContent = title === '每日目标' ? opt + ' 个番茄' : opt + ' 分钟';
                
                let optValue = title === '每日目标' ? opt + '个' : opt + '分钟';
                if (optValue === currentValue) {
                    btn.style.borderColor = 'var(--color-wisteria)';
                    btn.style.background = 'var(--color-light-purple)';
                }
                
                btn.onclick = function() {
                    selectPickerOption(opt);
                };
                container.appendChild(btn);
            });
            
            document.getElementById('picker-modal').style.display = 'flex';
        }
        
        function selectPickerOption(value) {
            if (pickerTarget === '专注时长') {
                settings.focusDuration = value;
            } else if (pickerTarget === '休息时长') {
                settings.breakDuration = value;
            } else if (pickerTarget === '每日目标') {
                settings.dailyGoal = value;
            }
            saveSettings();
            applySettings();
            closePicker();
        }
        
        function closePicker() {
            document.getElementById('picker-modal').style.display = 'none';
        }
        
        function clearAllData() {
            if (confirm('确定要清除所有数据吗？这将重置所有记录、任务和设置哦~')) {
                localStorage.removeItem('pomodoro_tasks');
                localStorage.removeItem('pomodoro_completions');
                localStorage.removeItem('pomodoro_streak');
                localStorage.removeItem('pomodoro_interruptions');
                localStorage.removeItem('pomodoro_chat_history');
                localStorage.removeItem('pomodoro_brain_dump');
                localStorage.removeItem('pomodoro_planb');
                settings = {...defaultSettings};
                saveSettings();
                applySettings();
                alert('数据已清除~');
            }
        }
        
        function handleAvatarUpload(e) {
            const file = e.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function(ev) {
                const dataUrl = ev.target.result;
                localStorage.setItem('pomodoro_avatar', dataUrl);
                updateAvatarPreview(dataUrl);
            };
            reader.readAsDataURL(file);
            e.target.value = '';
        }
        
        function updateAvatarPreview(src) {
            const preview = document.getElementById('avatar-preview');
            if (src) {
                preview.innerHTML = `<img src="${src}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">`;
            }
        }
        
        function editName() {
            const current = localStorage.getItem('pomodoro_name') || '';
            const name = prompt('请输入你的昵称~', current);
            if (name !== null) {
                const trimmed = name.trim() || '宝宝';
                localStorage.setItem('pomodoro_name', trimmed);
                document.getElementById('profile-name-desc').textContent = trimmed;
            }
        }

        function editDeerName() {
            const current = localStorage.getItem('pomodoro_deer_name') || '小鹿';
            const name = prompt('给陪伴你的小鹿起个名字吧~', current);
            if (name !== null) {
                const trimmed = name.trim() || '小鹿';
                localStorage.setItem('pomodoro_deer_name', trimmed);
                document.getElementById('deer-name-desc').textContent = trimmed;
            }
        }

        function editDeerCall() {
            const current = localStorage.getItem('pomodoro_deer_call') || '宝宝';
            const name = prompt('小鹿平时怎么称呼你呀~', current);
            if (name !== null) {
                const trimmed = name.trim() || '宝宝';
                localStorage.setItem('pomodoro_deer_call', trimmed);
                document.getElementById('deer-call-desc').textContent = trimmed;
            }
        }
        
        function handleWallpaperUpload(e) {
            const file = e.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function(ev) {
                const dataUrl = ev.target.result;
                localStorage.setItem('pomodoro_wallpaper', dataUrl);
                localStorage.removeItem('pomodoro_wallpaper_color');
                updateWallpaperPreview(dataUrl);
                document.getElementById('wallpaper-desc').textContent = '已上传图片';
                // 清除颜色选项的高亮
                document.querySelectorAll('.wallpaper-color-option').forEach(opt => {
                    opt.classList.remove('active');
                    opt.style.border = '3px solid transparent';
                });
            };
            reader.readAsDataURL(file);
            e.target.value = '';
        }
        
        function updateWallpaperPreview(src) {
            const preview = document.getElementById('wallpaper-preview');
            if (src) {
                preview.innerHTML = `<img src="${src}" style="width:100%;height:100%;object-fit:cover;border-radius:12px;">`;
            }
        }
        
        function selectWallpaperColor(color, el) {
            document.querySelectorAll('.wallpaper-color-option').forEach(opt => {
                opt.classList.remove('active');
                opt.style.border = '3px solid transparent';
            });
            el.classList.add('active');
            el.style.border = '3px solid var(--color-wisteria)';
            
            // 保存颜色到 localStorage
            localStorage.setItem('pomodoro_wallpaper_color', color);
            // 清除已有图片壁纸
            localStorage.removeItem('pomodoro_wallpaper');
            
            const desc = document.getElementById('wallpaper-desc');
            const colorNames = {
                'default': '渐变默认',
                '#FFF5F5': '柔雾粉',
                '#F0E8FF': '薰衣草紫',
                '#E8F8F0': '薄荷绿',
                '#E8F0FF': '天空蓝',
                '#FFF8E0': '奶油黄',
                '#FFF0F0': '暖粉',
                '#F5F5F5': '浅灰'
            };
            desc.textContent = colorNames[color] || '自定义颜色';
            
            // 恢复壁纸预览图标
            const preview = document.getElementById('wallpaper-preview');
            preview.innerHTML = `<svg viewBox="0 0 40 40" fill="white" width="24" height="24">
                                <rect x="4" y="4" width="32" height="24" rx="4" fill="white" opacity="0.6"/>
                                <circle cx="12" cy="12" r="4" fill="#FFD700"/>
                                <path d="M4 22 L14 14 L24 20 L36 10 L36 28 L4 28Z" fill="#C9A7EB" opacity="0.6"/>
                            </svg>`;
        }
        
        function loadProfile() {
            const avatar = localStorage.getItem('pomodoro_avatar');
            if (avatar) updateAvatarPreview(avatar);

            const name = localStorage.getItem('pomodoro_name');
            if (name) document.getElementById('profile-name-desc').textContent = name;

            const wallpaper = localStorage.getItem('pomodoro_wallpaper');
            const wallpaperColor = localStorage.getItem('pomodoro_wallpaper_color');
            const wallpaperDesc = document.getElementById('wallpaper-desc');
            if (wallpaper) {
                updateWallpaperPreview(wallpaper);
                wallpaperDesc.textContent = '已上传图片';
            } else if (wallpaperColor) {
                wallpaperDesc.textContent = '已选择颜色';
                // 高亮对应的颜色选项
                document.querySelectorAll('.wallpaper-color-option').forEach(opt => {
                    opt.classList.remove('active');
                    opt.style.border = '3px solid transparent';
                    if (opt.getAttribute('data-wallpaper-color') === wallpaperColor) {
                        opt.classList.add('active');
                        opt.style.border = '3px solid var(--color-wisteria)';
                    }
                });
            } else {
                wallpaperDesc.textContent = '点击上传图片，或选择下方颜色';
                // 默认选中第一个（渐变默认）
                const firstOpt = document.querySelector('.wallpaper-color-option');
                if (firstOpt) {
                    firstOpt.classList.add('active');
                    firstOpt.style.border = '3px solid #C9A7EB';
                }
            }

            const deerName = localStorage.getItem('pomodoro_deer_name') || '小鹿';
            document.getElementById('deer-name-desc').textContent = deerName;

            const deerCall = localStorage.getItem('pomodoro_deer_call') || '宝宝';
            document.getElementById('deer-call-desc').textContent = deerCall;
        }
        
        function toggleDarkMode() {
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            const newMode = !isDark;
            applyDarkMode(newMode);
            localStorage.setItem('pomodoro_dark_mode', newMode ? 'dark' : 'light');
        }
        
        function applyDarkMode(isDark) {
            const toggle = document.getElementById('dark-toggle');
            const desc = document.getElementById('dark-mode-desc');
            if (isDark) {
                document.documentElement.setAttribute('data-theme', 'dark');
                toggle.classList.add('active');
                desc.textContent = '开启';
            } else {
                document.documentElement.removeAttribute('data-theme');
                toggle.classList.remove('active');
                desc.textContent = '关闭';
            }
        }
        
        function selectThemeColor(accent, el) {
            document.querySelectorAll('.theme-color-option').forEach(opt => {
                opt.classList.remove('active');
                opt.style.border = '3px solid transparent';
            });
            el.classList.add('active');
            el.style.border = '3px solid ' + (accent === 'default' ? '#C9A7EB' : (accent === 'pink' ? '#FF8FAB' : accent === 'blue' ? '#8BB8F0' : accent === 'green' ? '#8BC8A0' : '#F0B878'));
            
            document.documentElement.removeAttribute('data-accent');
            if (accent !== 'default') {
                document.documentElement.setAttribute('data-accent', accent);
            }
            localStorage.setItem('pomodoro_accent', accent);
        }
        
        function loadTheme() {
            const darkMode = localStorage.getItem('pomodoro_dark_mode');
            applyDarkMode(darkMode === 'dark');
            
            const accent = localStorage.getItem('pomodoro_accent') || 'default';
            if (accent !== 'default') {
                document.documentElement.setAttribute('data-accent', accent);
            }
            document.querySelectorAll('.theme-color-option').forEach(opt => {
                opt.classList.remove('active');
                opt.style.border = '3px solid transparent';
                if (opt.getAttribute('data-accent') === accent) {
                    opt.classList.add('active');
                    const borderColor = accent === 'default' ? '#C9A7EB' : (accent === 'pink' ? '#FF8FAB' : accent === 'blue' ? '#8BB8F0' : accent === 'green' ? '#8BC8A0' : '#F0B878');
                    opt.style.border = '3px solid ' + borderColor;
                }
            });
        }
        
        function openPage(page) {
            window.location.href = page;
        }
        
        document.querySelectorAll('.setting-item').forEach(item => {
            const titleEl = item.querySelector('.setting-title');
            if (!titleEl) return;
            const title = titleEl.textContent.trim();
            if (['专注时长', '休息时长', '每日目标'].includes(title)) {
                item.addEventListener('click', function() { openPicker(item); });
            }
        });
        
        loadSettings();
        loadProfile();
        loadTheme();
    </script>
</body>
