            <div class="timer-container">
                <svg width="320" height="320" viewBox="0 0 320 320">
                    <defs>
                        <linearGradient id="wheelGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" style="stop-color:#FFE4E6;stop-opacity:0.9"/>
                            <stop offset="50%" style="stop-color:#FFCCCF;stop-opacity:0.6"/>
                            <stop offset="100%" style="stop-color:var(--color-warm-pink);stop-opacity:0.4"/>
                        </linearGradient>
                        <radialGradient id="inner-glow" cx="50%" cy="50%" r="50%">
                            <stop offset="0%" style="stop-color:#FFFFFF;stop-opacity:0.3"/>
