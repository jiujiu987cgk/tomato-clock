<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI对话</title>
    <link rel="manifest" href="manifest.json">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="番茄钟">
    <link rel="apple-touch-icon" href="assets/icons/icon-192.svg">
    <link rel="stylesheet" href="assets/css/styles.css">
    <style>
        .content-area {
            padding: 0;
            padding-bottom: 230px;
            height: calc(100vh - 54px);
            display: flex;
            flex-direction: column;
        }
        
        .chat-header {
            background: linear-gradient(135deg, var(--color-wisteria) 0%, #B895D6 50%, #A880C6 100%);
            padding: 14px 18px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 4px 16px rgba(201, 167, 235, 0.35);
            position: relative;
        }
        
        .chat-header::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            right: 0;
            height: 8px;
            background: linear-gradient(180deg, rgba(201,167,235,0.25) 0%, transparent 100%);
        }
        
        .header-back {
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255,255,255,0.25);
            border-radius: 50%;
            cursor: pointer;
            transition: background 0.2s;
            backdrop-filter: blur(4px);
        }
        
        .header-back:hover {
            background: rgba(255,255,255,0.4);
        }
        
        .deer-avatar-lg {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: rgba(255,255,255,0.25);
            padding: 2px;
            box-shadow: 0 0 0 2px rgba(255,255,255,0.4), 0 4px 12px rgba(0,0,0,0.1);
        }
        
        .header-info {
            flex: 1;
        }
        
        .header-info h2 {
            font-size: 17px;
            color: white;
            margin-bottom: 2px;
            text-shadow: 0 1px 3px rgba(0,0,0,0.15);
        }
        
        .online-status {
            display: flex;
            align-items: center;
            gap: 6px;
        }
        
        .online-dot {
            width: 8px;
            height: 8px;
            background: var(--color-mint-green);
            border-radius: 50%;
            animation: pulse-dot 2s ease-in-out infinite;
            box-shadow: 0 0 6px rgba(181, 234, 215, 0.8);
        }
        
        .online-status span {
            font-size: 11px;
            color: rgba(255,255,255,0.85);
        }
        
        .clear-btn {
            background: rgba(255,255,255,0.25);
            backdrop-filter: blur(4px);
            border: none;
            border-radius: 12px;
            padding: 6px 12px;
            color: white;
            font-family: var(--font-family-display);
            font-size: 12px;
            cursor: pointer;
            transition: background 0.2s;
        }
        
        .clear-btn:hover {
            background: rgba(255,255,255,0.4);
        }
        
        .emotion-bar {
            background: linear-gradient(180deg, #FFFFFF 0%, var(--color-cream-white) 100%);
            padding: 12px 16px;
            display: flex;
            gap: 10px;
            overflow-x: auto;
            border-bottom: 1px solid rgba(232, 213, 245, 0.6);
            box-shadow: 0 2px 8px rgba(201, 167, 235, 0.06);
        }
        
        .emotion-bar::-webkit-scrollbar { height: 0; }
        
        .emotion-tag {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            padding: 8px 12px;
            background: linear-gradient(135deg, var(--color-cream-yellow) 0%, #FFE8F5 100%);
            border-radius: 16px;
            cursor: pointer;
            transition: all 0.25s;
            flex-shrink: 0;
            border: 1.5px solid transparent;
            min-width: 56px;
        }
        
        .emotion-tag:hover {
            background: linear-gradient(135deg, var(--color-light-purple) 0%, #FFE8F5 100%);
            transform: translateY(-1px);
            box-shadow: 0 4px 10px rgba(201, 167, 235, 0.2);
        }
        
        .emotion-tag.active {
            background: linear-gradient(135deg, var(--color-wisteria) 0%, #B895D6 100%);
            box-shadow: 0 4px 12px rgba(201, 167, 235, 0.45);
            border-color: rgba(255,255,255,0.6);
        }
        
        .emotion-tag.active span {
            color: white;
        }
        
        .emotion-icon {
            width: 32px;
            height: 32px;
        }
        
        .emotion-tag span {
            font-size: 11px;
            color: var(--color-warm-gray);
        }
        
        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 18px 16px;
            background: linear-gradient(180deg, var(--color-cream-white) 0%, #FFF5F8 100%);
            scroll-behavior: smooth;
        }
        
        .message {
            display: flex;
            gap: 10px;
            margin-bottom: 18px;
            animation: msg-in 0.35s ease-out;
        }
        
        @keyframes msg-in {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .message.user {
            flex-direction: row-reverse;
        }
        
        .message-avatar {
            width: 38px;
            height: 38px;
            flex-shrink: 0;
            border-radius: 50%;
            background: rgba(255,255,255,0.6);
            box-shadow: 0 2px 6px rgba(201, 167, 235, 0.15);
        }
        
        .message-bubble {
            max-width: 75%;
            padding: 11px 15px;
            border-radius: 18px;
            position: relative;
        }
        
        .message-bubble.ai {
            background: linear-gradient(135deg, var(--color-light-purple) 0%, var(--color-light-purple) 100%);
            border-radius: 18px 18px 18px 4px;
            box-shadow: 0 3px 10px rgba(201, 167, 235, 0.2);
        }
        
        .message-bubble.user {
            background: linear-gradient(135deg, #FF8888 0%, var(--color-berry-red) 100%);
            color: white;
            border-radius: 18px 18px 4px 18px;
            box-shadow: 0 3px 10px rgba(255, 107, 107, 0.3);
        }
        
        .message-text {
            font-size: 14px;
            line-height: 1.55;
        }
        
        .message-text.user {
            color: white;
        }
        
        .system-message {
            text-align: center;
            margin-bottom: 18px;
        }
        
        .system-content {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: linear-gradient(135deg, rgba(255, 243, 224, 0.95) 0%, rgba(232, 213, 245, 0.4) 100%);
            padding: 10px 16px;
            border-radius: 16px;
            border: 1px solid rgba(201, 167, 235, 0.2);
            box-shadow: 0 2px 8px rgba(201, 167, 235, 0.1);
        }
        
        .system-deer {
            width: 36px;
            height: 36px;
        }
        
        .system-content p {
            font-size: 11px;
            color: var(--color-warm-gray);
            margin: 0;
        }
        
        .quick-commands {
            position: fixed;
            bottom: 152px;
            left: 50%;
            transform: translateX(-50%);
            width: 393px;
            padding: 10px 12px 12px;
            display: flex;
            gap: 8px;
            justify-content: space-between;
            background: rgba(255, 251, 247, 0.96);
            backdrop-filter: blur(10px);
            border-top: 1px solid rgba(232, 213, 245, 0.4);
            box-shadow: 0 -4px 16px rgba(201, 167, 235, 0.08);
            z-index: 90;
        }
        
        .quick-commands::-webkit-scrollbar { height: 0; }
        
        .quick-btn {
            flex: 1;
            background: linear-gradient(135deg, #FFFFFF 0%, var(--color-cream-yellow) 100%);
            border: 1.5px solid rgba(201, 167, 235, 0.4);
            border-radius: 16px;
            padding: 10px 6px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: 0 2px 8px rgba(201, 167, 235, 0.1);
            min-width: 0;
        }
        
        .quick-btn:hover {
            background: linear-gradient(135deg, var(--color-cream-yellow) 0%, #FFE8F5 100%);
            border-color: var(--color-wisteria);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(201, 167, 235, 0.25);
        }
        
        .quick-btn:active {
            transform: scale(0.95);
        }
        
        .quick-icon {
            width: 30px;
            height: 30px;
        }
        
        .quick-btn span {
            font-size: 11px;
            color: var(--color-deep-purple-gray);
        }
        
        .input-area {
            position: fixed;
            bottom: 83px;
            left: 50%;
            transform: translateX(-50%);
            width: 393px;
            padding: 10px 16px;
            background: rgba(255, 255, 255, 0.96);
            backdrop-filter: blur(10px);
            border-top: 1px solid rgba(232, 213, 245, 0.6);
            box-shadow: 0 -4px 16px rgba(201, 167, 235, 0.1);
        }
        
        .input-wrapper {
            display: flex;
            align-items: center;
            gap: 10px;
            background: linear-gradient(135deg, var(--color-cream-yellow) 0%, #FFE8F5 100%);
            border: 1.5px solid rgba(232, 213, 245, 0.7);
            border-radius: 30px;
            padding: 7px 8px 7px 14px;
            transition: all 0.3s;
            box-shadow: inset 0 1px 3px rgba(255,255,255,0.6);
        }
        
        .input-wrapper:focus-within {
            border-color: var(--color-wisteria);
            box-shadow: 0 0 0 3px rgba(201, 167, 235, 0.15), inset 0 1px 3px rgba(255,255,255,0.6);
            background: white;
        }
        
        .chat-input {
            flex: 1;
            background: transparent;
            border: none;
            font-family: var(--font-family-display);
            font-size: 14px;
            color: var(--color-deep-purple-gray);
            outline: none;
        }
        
        .chat-input::placeholder {
            color: #B8A8C8;
        }
        
        .typing-indicator {
            display: flex;
            align-items: center;
            gap: 4px;
            padding: 12px 16px;
        }
        
        .typing-dot {
            width: 7px;
            height: 7px;
            background: var(--color-wisteria);
            border-radius: 50%;
            animation: typing-bounce 1.4s ease-in-out infinite;
        }
        
        .typing-dot:nth-child(2) { animation-delay: 0.2s; }
        .typing-dot:nth-child(3) { animation-delay: 0.4s; }
        
        @keyframes typing-bounce {
            0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
            30% { transform: translateY(-6px); opacity: 1; }
        }
        
        @keyframes pulse-dot {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.3); opacity: 0.7; }
        }
        
        .send-btn {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, var(--color-wisteria) 0%, #B895D6 100%);
            border: none;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            box-shadow: 0 3px 10px rgba(201, 167, 235, 0.4);
            flex-shrink: 0;
        }
        
        .send-btn:active {
            transform: scale(0.9);
        }
        
        .send-btn:hover {
            box-shadow: 0 4px 14px rgba(201, 167, 235, 0.55);
        }
    </style>
</head>
